{
  "name": "lumberlake-instance",
  "version": "1.0.0",
  "description": "kennel lumberlake website",
  "main": "tailwind.config.js",
  "scripts": {
    "tailwind:build": "tailwindcss -i ./src/main/resources/static/css/input.css -o ./src/main/resources/static/css/style.css",
    "tailwind:watch": "tailwindcss -i ./src/main/resources/static/css/input.css -o ./src/main/resources/static/css/style.css --watch",
    "webpack": "webpack --config webpack.config.js",
    "webpack:watch": "webpack --config webpack.config.js --watch"
  },
  "repository": {
    "type": "git",
    "url": "lumberlake-instance"
  },
  "keywords": [
    "lumberlake",
    "kennel",
    "website"
  ],
  "author": "Tristan Arts",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "html-webpack-plugin": "^5.6.6",
    "tailwindcss": "^4.2.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
